# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "A local LeetCode-style judge for OCaml submissions"
depends: [
  "dune" {>= "3.21"}
  "ocaml"
  "base"
  "stdio"
  "core"
  "core_unix"
  "ppx_jane"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
